# PostgreSQL
POSTGRES_DB=local_rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

# Провайдеры эмбеддингов и реранкера. Включите и заполните те, что выбраны
# в rag.config.yaml (поля embeddings.provider / reranker.provider).

# Jina AI — embeddings + reranker. https://jina.ai/embeddings/
# JINA_API_KEY=your_jina_api_key_here

# OpenAI — embeddings.
# OPENAI_API_KEY=your_openai_api_key_here

# SiliconFlow — embeddings + reranker (Qwen3 и др.). https://siliconflow.com
# SILICONFLOW_API_KEY=your_siliconflow_api_key_here
